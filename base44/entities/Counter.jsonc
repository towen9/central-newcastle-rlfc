{
  "name": "Counter",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Unique counter key (e.g. founding_members, halftime_drops_remaining)"
    },
    "value": {
      "type": "number",
      "default": 0,
      "description": "Current counter value"
    }
  },
  "required": [
    "key"
  ]
}